# ──────────────────────────────────────────────────────────────────────────────
# MDC assessment tool — AI analysis configuration (OPTIONAL, bring-your-own-API)
# ──────────────────────────────────────────────────────────────────────────────
#
# The AI step is entirely optional. The assessment and deployment tools work
# without it. To enable AI analysis, copy this file to ".env" and fill in your
# own provider details, OR export these as environment variables.
#
#     cp .env.example .env
#
# Your API key stays on your machine. It is read from the environment only and is
# never logged, printed, or written to any output file. Do NOT commit your .env.
#
# Supported providers: openai | azure | anthropic | openai-compatible
# ──────────────────────────────────────────────────────────────────────────────

# Which provider's API contract to use.
MDC_AI_PROVIDER=openai

# Your secret API key (required to enable AI).
MDC_AI_API_KEY=

# Model / deployment name (optional — a sensible default is used per provider).
# MDC_AI_MODEL=gpt-4o-mini

# Override the API base URL (optional — only needed for self-hosted/Azure/etc.).
# MDC_AI_BASE_URL=

# ── Provider-specific examples ────────────────────────────────────────────────
#
# OpenAI (default):
#     MDC_AI_PROVIDER=openai
#     MDC_AI_API_KEY=sk-...
#     MDC_AI_MODEL=gpt-4o-mini
#
# Azure OpenAI (MDC_AI_MODEL is your *deployment* name, base URL is your resource):
#     MDC_AI_PROVIDER=azure
#     MDC_AI_API_KEY=<azure-openai-key>
#     MDC_AI_MODEL=<your-deployment-name>
#     MDC_AI_BASE_URL=https://<your-resource>.openai.azure.com
#     MDC_AI_API_VERSION=2024-06-01
#
# Anthropic:
#     MDC_AI_PROVIDER=anthropic
#     MDC_AI_API_KEY=sk-ant-...
#     MDC_AI_MODEL=claude-3-5-sonnet-latest
#
# Local Ollama (no key needed by Ollama, but set any non-empty value to enable):
#     MDC_AI_PROVIDER=openai-compatible
#     MDC_AI_API_KEY=ollama
#     MDC_AI_MODEL=llama3.1
#     MDC_AI_BASE_URL=http://localhost:11434/v1
#
# OpenRouter / LM Studio / other OpenAI-compatible gateways:
#     MDC_AI_PROVIDER=openai-compatible
#     MDC_AI_API_KEY=<gateway-key>
#     MDC_AI_MODEL=<model-id>
#     MDC_AI_BASE_URL=https://openrouter.ai/api/v1
